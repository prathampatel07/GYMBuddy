# ───────────────────────────────────────────────
# GymBuddy Backend — Environment Variables
# Copy this to .env and fill in your values
# ───────────────────────────────────────────────

# ── Server ────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── JWT Auth ──────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_64
JWT_EXPIRY=30d

# ── Database ──────────────────────────────────
# MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/gymbuddy
# Leave blank to run in MOCK (file-based) mode
MONGODB_URI=

# ── Cloudinary (file uploads) ─────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://gymbuddy.vercel.app,http://localhost:5173

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_LIMIT_MAX=15

# ── Logging ───────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_DIR=logs

# ── Monitoring ────────────────────────────────
# Internal monitoring token (keep secret)
MONITORING_SECRET=CHANGE_ME_monitoring_secret_token
ENABLE_METRICS=true

# ── Feature Flags ─────────────────────────────
FEATURE_AI_MATCHING=true
FEATURE_STREAK_VERIFICATION=true
FEATURE_REWARDS=true
FEATURE_LEADERBOARD=true
ENABLE_MAINTENANCE_MODE=false
