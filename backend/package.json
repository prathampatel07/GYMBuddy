{
  "name": "gym-buddy-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.json",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.json --testPathPatterns=tests/unit",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.json --testPathPatterns=tests/integration",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.json --coverage",
    "test:load": "node tests/load/loadTest.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
