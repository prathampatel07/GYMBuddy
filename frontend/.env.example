# ───────────────────────────────────────────────
# GymBuddy Frontend — Environment Variables
# Copy this to .env and fill in your values
# ───────────────────────────────────────────────

# Backend API URL (no trailing slash)
# Local dev:       http://localhost:5000/api
# Render prod:     https://gymbuddy-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# App metadata
VITE_APP_NAME=GymBuddy
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Feature flags (must match backend)
VITE_FEATURE_AI=true
VITE_FEATURE_LEADERBOARD=true
VITE_FEATURE_REWARDS=true

# Analytics (optional — Plausible/self-hosted)
VITE_ANALYTICS_DOMAIN=gymbuddy.app
VITE_ENABLE_ANALYTICS=false
